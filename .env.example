# Copy this file to .env. Never commit the real .env file.
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=
JWT_SECRET=
GRADING_SECRETS_FILE=
GRADING_REQUIRE_SECRETS=false
ADMIN_EMAILS=
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_NICKNAME=관리자

# Local frontend origin. Set the exact HTTPS production origin when deploying.
CORS_ALLOWED_ORIGINS=http://localhost:5173
SWAGGER_ENABLED=false

JUDGE0_BASE_URL=http://localhost:2358
JUDGE0_MOCK=true

# AI features. Put the real API key only in .env.
AI_ENABLED=false
AI_PROVIDER=mock
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest
